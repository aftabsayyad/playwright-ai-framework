{
  "name": "playwright-ai-framework",
  "version": "1.0.0",
  "description": "Production-grade AI-powered Playwright Test Automation Framework",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:dev": "cross-env ENV=dev playwright test",
    "test:stage": "cross-env ENV=stage playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test --grep @api",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:serve": "allure serve allure-results",
    "playwright:install": "playwright install --with-deps",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf allure-results allure-report test-results"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.13.0",
    "allure-playwright": "^3.0.0",
    "allure-commandline": "^2.30.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.3.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "ai",
    "pom",
    "allure"
  ],
  "author": "SDET Engineer",
  "license": "MIT"
}
